{
  "functions": {
    "api/data.js": {
      "includeFiles": "api/data-files/**"
    },
    "api/summary.js": {
      "includeFiles": "api/data-files/manifest.json"
    }
  },
  "rewrites": [
    {
      "source": "/home",
      "destination": "/"
    },
    {
      "source": "/database",
      "destination": "/"
    },
    {
      "source": "/mfl",
      "destination": "/"
    },
    {
      "source": "/progression",
      "destination": "/"
    },
    {
      "source": "/watchlist",
      "destination": "/"
    },
    {
      "source": "/watchlist/:id",
      "destination": "/"
    },
    {
      "source": "/my-players",
      "destination": "/"
    },
    {
      "source": "/evaluation",
      "destination": "/"
    },
    {
      "source": "/settings",
      "destination": "/"
    },
    {
      "source": "/changelog",
      "destination": "/"
    },
    {
      "source": "/players/:id",
      "destination": "/"
    }
  ],
  "ignoreCommand": "node vercel-ignore-git-deploy.js"
}
