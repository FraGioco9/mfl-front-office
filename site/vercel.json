{
  "functions": {
    "api/data.js": {
      "includeFiles": "api/data-files/**"
    },
    "api/summary.js": {
      "includeFiles": "api/data-files/manifest.json"
    }
  },
  "rewrites": [
    {
      "source": "/home",
      "destination": "/"
    },
    {
      "source": "/progression",
      "destination": "/"
    },
    {
      "source": "/watchlist",
      "destination": "/"
    },
    {
      "source": "/changelog",
      "destination": "/"
    },
    {
      "source": "/players/:id",
      "destination": "/"
    }
  ]
}
